<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Monthly Spending Goals"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Minimum Goal"
        android:layout_marginTop="24dp" />

    <TextView
        android:id="@+id/tvMinValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="R 500"
        android:textStyle="bold"
        android:layout_marginTop="8dp" />

    <SeekBar
        android:id="@+id/seekMin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="10000" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Maximum Goal"
        android:layout_marginTop="24dp" />

    <TextView
        android:id="@+id/tvMaxValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="R 5000"
        android:textStyle="bold"
        android:layout_marginTop="8dp" />

    <SeekBar
        android:id="@+id/seekMax"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="20000" />

    <Button
        android:id="@+id/btnSaveGoals"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Save Goals"
        android:layout_marginTop="32dp" />

</LinearLayout>