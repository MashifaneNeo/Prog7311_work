<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Balance Wise Dashboard"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTotalSpent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="R 0.00"
            android:textSize="20sp"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/tvMinGoal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Min Goal: R 500"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/tvMaxGoal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Max Goal: R 5000"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btnAddCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add Category"
            android:layout_marginTop="24dp" />

        <Button
            android:id="@+id/btnAddExpense"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add Expense"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btnGoals"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Set Monthly Goals"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btnExpenses"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="View Expenses"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btnCategoryTotals"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Category Totals"
            android:layout_marginTop="12dp" />

    </LinearLayout>
</ScrollView>